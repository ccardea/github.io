---
import type { CollectionEntry } from "astro:content";
interface Props {
    entry: CollectionEntry<'posts'>;
}
const {entry}= Astro.props;
const {title, description, pubDate, updated} = entry.data;
---
<div>
    <ul>
        <li><a href=`/posts/${entry.id}` class="title">{title}</a> </li>
        <li>{description} </li>
        <li><span class="pubDate">First Published:</span> {pubDate.toDateString()}</li>
        <li><span class="pubDate">Last updated:</span> {updated?.toDateString()}</li>
    </ul>
</div>
<style>
    ul {
        list-style-type: none;
    }
    .title{
        color: var(--accent);
        font-weight: bold;
    }
    .pubDate {
        font-weight: bold;
    }
</style>
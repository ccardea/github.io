---
import { SITE_TITLE } from "../consts";
---
<header>
  <div id="site-title">
    <h1>
      <a href="/">{SITE_TITLE}</a>
    </h1>
  </div>
  <nav>
    <a href="/">Home</a>
    <a href="/about">About</a>
  </nav>
</header>

<style>
header {
  width: 100%;
  min-height: 4rem;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  box-shadow: 0 1px 1px rgba(15, 23, 42, 0.05);
}

nav {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 1.25rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 4rem;
}

a {
  color: var(--text);
  text-decoration: none;
  font-weight: 600;
  transition: color 0.2s ease, transform 0.2s ease;
}

a:hover,
a:focus-visible {
  color: var(--accent);
  transform: translateY(-1px);
}

#site-title {
  width: 100%;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 1.25rem;
  box-sizing: border-box;
}

#site-title > h1 > a{
  color: var(--accent);  
}
</style>
